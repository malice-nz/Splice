local Sandbox = {}

-- Capture host environment at module load time, before any function boundary
local HostEnv = (getfenv :: any)()

-- All Roblox globals to forward from the host environment
local RobloxGlobals = {
	-- Core
	"game", "workspace", "script", "plugin",

	-- Scheduling
	"task", "wait", "delay", "spawn", "tick", "time", "elapsedTime",

	-- Instance creation
	"Instance", "Enum",

	-- Math types
	"Vector3", "Vector2", "Vector3int16", "Vector2int16",
	"CFrame",
	"UDim", "UDim2",
	"Color3", "BrickColor",
	"Rect", "Ray", "Region3", "Region3int16",
	"NumberSequence", "NumberSequenceKeypoint",
	"ColorSequence", "ColorSequenceKeypoint",
	"NumberRange",
	"TweenInfo",
	"PhysicalProperties",
	"Font",
	"Axes", "Faces",
	"OverlapParams", "RaycastParams",
	"SharedTable",
	"DateTime", "Random",
	"PathWaypoint",
	"FloatCurveKey",
	"RotationCurveKey",
	"DockWidgetPluginGuiInfo",
	"CatalogSearchParams",

	-- Networking / data
	"Shared", "shared", "_G",

	-- Debugging
	"printidentity", "stats", "Stats",
	"debug",
	"gcinfo",
	"version",
}

-- Lua stdlib to always include
local StdlibEntries = {
	-- I/O
	print = print,
	warn = warn,
	error = error,
	assert = assert,

	-- Type system
	type = type,
	typeof = typeof,
	tostring = tostring,
	tonumber = tonumber,

	-- Table introspection
	rawget = rawget,
	rawset = rawset,
	rawequal = rawequal,
	rawlen = rawlen,
	setmetatable = setmetatable,
	getmetatable = getmetatable,

	-- Iterators
	ipairs = ipairs,
	pairs = pairs,
	next = next,

	-- Multiple returns
	select = select,
	unpack = unpack or table.unpack,

	-- Error handling
	pcall = pcall,
	xpcall = xpcall,

	-- Module loading
	require = require,
	newproxy = newproxy,

	-- Standard libraries
	math = math,
	string = string,
	table = table,
	coroutine = coroutine,
	os = os,
	bit32 = bit32,
	buffer = buffer,
	utf8 = utf8,

	_VERSION = _VERSION,
}

export type SandboxConfig = {
	Whitelist: { string }?,
	Blacklist: { string }?,
	Wrappers: { [string]: (any) -> any }?,
	BlockedServices: { string }?,
	Script: any?,
	Globals: { [string]: any }?,
	CallerEnv: { [string]: any }?,
}

local function WrapGetService(RealGame: any, Blocked: { [string]: true })
	local Original = RealGame.GetService
	return function(self, ServiceName: string, ...)
		if Blocked[ServiceName] then
			error(`[Sandbox] Access to service "{ServiceName}" is blocked`, 2)
		end
		return Original(self, ServiceName, ...)
	end
end

local function WrapFindService(RealGame: any, Blocked: { [string]: true })
	local Original = RealGame.FindService
	if not Original then return nil end
	return function(self, ServiceName: string, ...)
		if Blocked[ServiceName] then
			return nil
		end
		return Original(self, ServiceName, ...)
	end
end

local function CreateGameProxy(RealGame: any, BlockedSet: { [string]: true }): any
	local Proxy = newproxy(true)
	local MT = getmetatable(Proxy) :: any

	MT.__index = function(_, Key)
		if Key == "GetService" then
			return WrapGetService(RealGame, BlockedSet)
		end
		if Key == "FindService" then
			return WrapFindService(RealGame, BlockedSet)
		end
		return (RealGame :: any)[Key]
	end

	MT.__newindex = function(_, Key, Value)
		(RealGame :: any)[Key] = Value
	end

	MT.__tostring = function()
		return tostring(RealGame)
	end

	MT.__metatable = "The metatable is locked"

	return Proxy
end

function Sandbox.CreateEnv(Config: SandboxConfig?): { [string]: any }
	local Cfg = Config or {}
	local Env = {}

	-- Start with Lua stdlib
	for Key, Value in StdlibEntries do
		Env[Key] = Value
	end

	-- Handle vector (may be function or table)
	local Vec = (rawget :: any)(_G, "vector") or (vector :: any?)
	if type(Vec) == "function" then
		Env.vector = Vec
	elseif type(Vec) == "table" and (Vec :: any).create then
		Env.vector = setmetatable({}, {
			__index = Vec,
			__call = function(_, ...)
				return (Vec :: any).create(...)
			end,
		})
	end

	-- Forward Roblox globals from host
	local WhitelistSet: { [string]: true }? = nil
	if Cfg.Whitelist then
		WhitelistSet = {}
		for _, Name in Cfg.Whitelist do
			(WhitelistSet :: any)[Name] = true
		end
	end

	local BlacklistSet: { [string]: true } = {}
	if Cfg.Blacklist then
		for _, Name in Cfg.Blacklist do
			BlacklistSet[Name] = true
		end
	end

	for _, Name in RobloxGlobals do
		-- Filter by whitelist/blacklist
		if WhitelistSet and not (WhitelistSet :: any)[Name] then
			continue
		end
		if BlacklistSet[Name] then
			continue
		end

		-- Try host environment first (captured at module load), then caller, then _G
		local ok, val = pcall(function()
			return HostEnv[Name]
		end)
		if (not ok or val == nil) and Cfg.CallerEnv then
			ok, val = pcall(function()
				return (Cfg.CallerEnv :: any)[Name]
			end)
		end
		if not ok or val == nil then
			ok, val = pcall(function()
				return (rawget :: any)(_G, Name) or (_G :: any)[Name]
			end)
		end
		if ok and val ~= nil then
			Env[Name] = val
		end
	end

	-- Override script if provided
	if Cfg.Script ~= nil then
		Env.script = Cfg.Script
	end

	-- Handle blocked services by wrapping game
	if Cfg.BlockedServices and #Cfg.BlockedServices > 0 and Env.game then
		local BlockedSet: { [string]: true } = {}
		for _, Svc in Cfg.BlockedServices do
			BlockedSet[Svc] = true
		end
		Env.game = CreateGameProxy(Env.game, BlockedSet)

		-- workspace might also need updating if game was wrapped
		if Env.workspace == nil and Env.game then
			pcall(function()
				Env.workspace = Env.game:GetService("Workspace")
			end)
		end
	end

	-- Apply user-defined wrappers
	if Cfg.Wrappers then
		for Name, WrapperFn in Cfg.Wrappers do
			local Original = Env[Name]
			Env[Name] = WrapperFn(Original)
		end
	end

	-- Merge custom globals
	if Cfg.Globals then
		for Key, Value in Cfg.Globals do
			Env[Key] = Value
		end
	end

	return Env
end

return Sandbox
